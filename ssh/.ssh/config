# SSH client configuration
# ~/.ssh/config

# ── Global defaults ───────────────────────────────────────────────────────────
Host *
    # Keep connections alive
    ServerAliveInterval 60
    ServerAliveCountMax 3

    # Compress data in transit
    Compression yes

    # Connection multiplexing — reuse established connections
    # Speeds up git push/pull and mosh handshake on repeat connections
    ControlMaster auto
    ControlPath   ~/.ssh/sockets/%r@%h:%p
    ControlPersist 10m

    # Forward SSH agent so you don't need to re-enter passphrases on servers
    AddKeysToAgent yes

    # Default key (ed25519 preferred)
    IdentityFile ~/.ssh/id_ed25519
    IdentityFile ~/.ssh/id_rsa

    # Harden defaults
    HashKnownHosts yes
    VisualHostKey no

# ── Hosts ─────────────────────────────────────────────────────────────────────
# Add server entries below. For mosh, use the same Host block:
#   Connect with: mosh myserver
#   Or explicitly: mosh --ssh="ssh -p 2222" myserver -- nu
#
# Example:
# Host myserver
#     HostName server.example.com
#     User     myah
#     Port     22
#     IdentityFile ~/.ssh/id_ed25519
#     ForwardAgent no
#
# GitHub (uses SSH key for git operations)
Host github.com
    HostName github.com
    User     git
    IdentityFile ~/.ssh/id_ed25519
    ControlMaster no   # GitHub doesn't support multiplexing
