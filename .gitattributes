# Ensure install.sh is executable when checked out on Linux/macOS
install.sh eol=lf
install.sh diff=shell

# Normalize baked-in /home/<user>/ absolute paths to a placeholder on commit,
# re-expand to this machine's $HOME on checkout — see git-filters/*.sh
zellij/.config/zellij/config.kdl filter=homepath
nvim/.config/nvim/lua/config/autocmds.lua filter=homepath

# Force LF line endings for all shell scripts and config files
*.sh       eol=lf
*.nu       eol=lf
*.toml     eol=lf
*.kdl      eol=lf
*.yaml     eol=lf
*.yml      eol=lf
*.lua      eol=lf
*.toml     eol=lf
*.conf     eol=lf
config     eol=lf
ripgreprc  eol=lf
.gitconfig eol=lf
.gitignore_global eol=lf
